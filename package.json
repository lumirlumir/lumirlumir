{
  "private": true,
  "name": "lumirlumir",
  "type": "module",
  "packageManager": "npm@11.11.0",
  "engines": {
    "node": "^20.19.6"
  },
  "scripts": {
    "prepare": "npm run sync-client && husky",
    "build": "node src/sync-server.js -d",
    "fix": "npm-run-all -c -l -p fix:*",
    "fix:eslint": "eslint --fix",
    "fix:prettier": "prettier . --write --ignore-unknown",
    "fix:markdownlint": "markdownlint **/*.md --fix",
    "lint": "npm-run-all -c -l -p lint:*",
    "lint:eslint": "eslint",
    "lint:prettier": "prettier . --check --ignore-unknown",
    "lint:editorconfig": "editorconfig-checker -config .editorconfig-checker.json",
    "lint:markdownlint": "markdownlint **/*.md",
    "sync-client": "node src/sync-client.js"
  },
  "dependencies": {
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "editorconfig-checker": "^6.1.1",
    "eslint": "^9.39.4",
    "eslint-config-bananass": "^0.6.1",
    "eslint-markdown": "^0.6.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "markdownlint-cli": "^0.48.0",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.8.3"
  }
}
